            recognition.start();
        } else {
            setInterval(() => { drawWave(Math.random() * 0.3); }, 200);
        }

        ctx.fillStyle = '#000';
        ctx.fillRect(0, 0, canvasW, canvasH);
        ctx.strokeStyle = '#331400';
        ctx.beginPath();
        ctx.moveTo(0, canvasH/2);
        ctx.lineTo(canvasW, canvasH/2);
        ctx.stroke();

