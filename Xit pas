        function drawWave(intensity) {
            ctx.fillStyle = 'rgba(0, 0, 0, 0.3)';
            ctx.fillRect(0, 0, canvasW, canvasH);
            
            ctx.beginPath();
            ctx.moveTo(0, canvasH / 2);
